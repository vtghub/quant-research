# Copy this file to .env at the repo root for the Docker Compose setup.
# `docker compose up` reads .env automatically for the ${VAR} substitutions
# in docker-compose.yml. All variables are optional -- sane dev defaults are
# baked into the compose file; override only what you need.

# --- Postgres (container-internal; the api/worker connect via the "postgres" service name) --
QRA_POSTGRES_USER=qra
QRA_POSTGRES_PASSWORD=qra
QRA_POSTGRES_DB=qra

# --- Auth -----------------------------------------------------------------
# Generate a real one, e.g.: python -c "import secrets; print(secrets.token_urlsafe(48))"
QRA_JWT_SECRET=change-me-to-a-random-secret-at-least-32-bytes-long

# --- Optional: live data vendors (only needed if you configure these sources in a pipeline config) --
# FRED_API_KEY=your_free_fred_key
# ALPHAVANTAGE_API_KEY=your_free_alphavantage_key
# NASDAQ_DATA_LINK_API_KEY=your_free_nasdaq_data_link_key
# SEC_EDGAR_USER_AGENT=Your Name your_email@example.com
