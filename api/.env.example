# Copy this file to api/.env for the native (no-Docker) local dev setup.
# uvicorn/celery both read api/.env automatically (see quant_research_api/settings.py).
# All variables are optional -- sane defaults are baked in; override only what you need.

# --- Database -----------------------------------------------------------
# Must match the user/password/db you created with `createuser` / `createdb`.
QRA_DATABASE_URL=postgresql+psycopg://qra:qra@localhost:5432/qra

# --- Redis (Celery broker + result backend) ------------------------------
QRA_REDIS_URL=redis://localhost:6379/0

# --- Auth -----------------------------------------------------------------
# Generate a real one, e.g.: python -c "import secrets; print(secrets.token_urlsafe(48))"
QRA_JWT_SECRET=change-me-to-a-random-secret-at-least-32-bytes-long
QRA_JWT_ALGORITHM=HS256
QRA_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- CORS -------------------------------------------------------------
# JSON list of origins allowed to call the API. The Vite dev server runs on :5173.
QRA_CORS_ORIGINS=["http://localhost:5173"]

# --- Artifacts --------------------------------------------------------
# Where per-run tearsheet files (markdown/PNG) get written, under <this>/<run_id>/.
QRA_ARTIFACTS_ROOT=api_data/reports

# --- Optional: live data vendors (only needed if you configure these sources) --
# FRED_API_KEY=your_free_fred_key
# ALPHAVANTAGE_API_KEY=your_free_alphavantage_key
# NASDAQ_DATA_LINK_API_KEY=your_free_nasdaq_data_link_key
# SEC_EDGAR_USER_AGENT="Your Name your_email@example.com"
